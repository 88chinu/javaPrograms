package pack1;
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;

public class ColorChanger implements ActionListener {
    JFrame frame;
    JLabel label;
    JButton btnRed, btnGreen, btnBlue;

    ColorChanger() {
        frame = new JFrame("Chnage Color"); // Matching PDF typo [cite: 7]
        frame.setSize(400, 300);
        frame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        frame.setLayout(null);

        label = new JLabel("Click on a button to change the frame color"); [cite: 10]
        label.setBounds(20, 20, 300, 25);
        frame.add(label);

        btnRed = new JButton("Red"); [cite: 11]
        btnRed.setBounds(20, 60, 80, 30);
        btnRed.addActionListener(this);
        frame.add(btnRed);

        btnGreen = new JButton("Green"); [cite: 12]
        btnGreen.setBounds(110, 60, 80, 30);
        btnGreen.addActionListener(this);
        frame.add(btnGreen);

        btnBlue = new JButton("Blue"); [cite: 13]
        btnBlue.setBounds(200, 60, 80, 30);
        btnBlue.addActionListener(this);
        frame.add(btnBlue);

        frame.setVisible(true);
    }

    public void actionPerformed(ActionEvent ae) {
        // getContentPane() is used to change the background of a JFrame
        if (ae.getSource() == btnRed) {
            frame.getContentPane().setBackground(Color.RED); [cite: 6]
        } else if (ae.getSource() == btnGreen) {
            frame.getContentPane().setBackground(Color.GREEN); [cite: 6]
        } else if (ae.getSource() == btnBlue) {
            frame.getContentPane().setBackground(Color.BLUE); [cite: 6]
        }
    }

    public static void main(String[] args) {
        new ColorChanger();
    }
}